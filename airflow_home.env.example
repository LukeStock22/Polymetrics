# Run "source airflow_home.env.example" from a shell that already has Airflow installed.
#
# Some Linuxlab/container sessions set CA-bundle env vars that point to files
# not present inside the runtime image. That breaks Airflow CLI commands that
# make local HTTP requests. Clear them here for this project shell.

unset SSL_CERT_FILE
unset REQUESTS_CA_BUNDLE
unset CURL_CA_BUNDLE

export AIRFLOW_HOME=/home/compute/l.d.stockbridge/Polymetrics
export AIRFLOW__CORE__DAGS_FOLDER=/home/compute/l.d.stockbridge/Polymetrics/dags
export AIRFLOW__CORE__PLUGINS_FOLDER=/home/compute/l.d.stockbridge/Polymetrics/plugins
#
# Airflow 3 promotes/uses LocalExecutor in this environment.
# Keeping this explicit avoids confusion with legacy SequentialExecutor defaults.
export AIRFLOW__CORE__EXECUTOR=LocalExecutor
#
# Use a node-local SQLite DB. Do not put the Airflow SQLite metadata DB on the
# shared home directory when scheduler / dag-processor / CLI may run from
# different Linuxlab sessions.
export AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=sqlite:////tmp/polymetrics_airflow.db

export POLYMARKET_SNOWFLAKE_CONN_ID=Snowflake
export POLYMARKET_SNOWFLAKE_DATABASE=PANTHER_DB
export POLYMARKET_MARKETS_DIR=/home/compute/l.d.stockbridge/Polymetrics/data/raw/gamma/markets
export POLYMARKET_ANALYTICS_CONFIG_PATH=/home/compute/l.d.stockbridge/Polymetrics/.streamlit/secrets.toml
export POLYMARKET_ANALYTICS_BUILD_MODE=incremental
export POLYMARKET_ANALYTICS_DATABASE=PANTHER_DB
export POLYMARKET_ANALYTICS_SCHEMA=ANALYTICS
export POLYMARKET_ANALYTICS_SITE_PACKAGES=/home/compute/l.d.stockbridge/Polymetrics/.analytics-site-packages
export PYTHONPATH=/home/compute/l.d.stockbridge/Polymetrics/.analytics-site-packages:/home/compute/l.d.stockbridge/Polymetrics/src:$PYTHONPATH
