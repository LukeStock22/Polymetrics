# PolyMetrics streaming env template.
# Copy to `.env.streaming` (gitignored) and source before running the
# producer or consumer:
#   set -a && source .env.streaming && set +a

# -------- Snowflake (key-pair auth; no password, no MFA) --------
export SNOWFLAKE_ACCOUNT=UNB02139
export SNOWFLAKE_USER=DOG
export SNOWFLAKE_ROLE=TRAINING_ROLE
export SNOWFLAKE_WAREHOUSE=DOG_WH
export SNOWFLAKE_DATABASE=DOG_DB
export SNOWFLAKE_PRIVATE_KEY_PATH=${HOME}/.snowflake_keys/rsa_key.p8

# -------- Kafka --------
# When running the producer on the same host as docker-compose, use
# localhost:9092.  From inside a docker container in the same compose
# network use kafka:29092.
export KAFKA_BOOTSTRAP_SERVERS=localhost:9092
export KAFKA_TOPIC_TRADES=polymarket.trades.raw
export KAFKA_TOPIC_BOOKS=polymarket.books.raw
export KAFKA_TOPIC_ANOMALIES=polymarket.anomalies
export KAFKA_CONSUMER_GROUP=polymetrics-snowflake-sink

# -------- Streamer subscription --------
# Top N markets by 24h volume (0 = all active markets)
export STREAM_TOP_N_MARKETS=200
export STREAM_MAX_ASSETS=400
